{
  "name": "final-mask",
  "version": "0.0.0",
  "description": "A vanilla, third party dependencies free, browser friendly, input mask library.",
  "keywords": [
    "form",
    "input",
    "input-mask",
    "mask",
    "vanilla"
  ],
  "homepage": "https://github.com/rafael-perini/final-mask#readme",
  "bugs": {
    "url": "https://github.com/rafael-perini/final-mask/issues"
  },
  "license": "MIT",
  "author": "Rafael Perini (https://github.com/rafael-perini)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafael-perini/final-mask.git",
    "home": "git+https://github.com/rafael-perini/final-mask.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config",
    "docs:dev": "vpr docs",
    "docs:build": "vpr pack:docs"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.9.4",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "@vitest/coverage-v8": "^4.1.9",
    "bumpp": "^11.1.0",
    "jsdom": "^29.1.1",
    "semantic-release": "^25.0.5",
    "typescript": "^6.0.3",
    "vite-plus": "^0.2.1",
    "vitepress": "^1.6.4",
    "vue": "^3.5.38"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/git",
      "@semantic-release/github"
    ]
  },
  "packageManager": "pnpm@11.6.0"
}
